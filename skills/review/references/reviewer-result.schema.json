{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reviewer-result",
  "type": "object",
  "required": [
    "document_type",
    "mode",
    "passed",
    "blocked",
    "score_or_grade",
    "blocking_items",
    "auto_repairs",
    "remaining_issues",
    "requires_user_confirmation",
    "candidate_rewrites",
    "iterations",
    "reached_max_iterations",
    "stopped_for_no_improvement",
    "user_receipt"
  ],
  "additionalProperties": false,
  "properties": {
    "document_type": { "type": "string", "enum": ["research", "prd", "dr", "spec", "plan"] },
    "mode": { "type": "string", "enum": ["quality", "feasibility"] },
    "passed": { "type": "boolean" },
    "blocked": { "type": "boolean" },
    "score_or_grade": { "type": ["number", "string"] },
    "blocking_items": { "type": "array", "items": { "type": "string" } },
    "auto_repairs": { "type": "array", "items": { "type": "string" } },
    "remaining_issues": { "type": "array", "items": { "type": "string" } },
    "requires_user_confirmation": { "type": "boolean" },
    "candidate_rewrites": { "type": "array", "items": { "type": "string" } },
    "iterations": { "type": "integer", "minimum": 0 },
    "reached_max_iterations": { "type": "boolean" },
    "stopped_for_no_improvement": { "type": "boolean" },
    "user_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_type",
        "executed_modes",
        "iterations",
        "auto_repairs_summary",
        "remaining_or_confirmation_items",
        "blocked",
        "quality_summary"
      ],
      "properties": {
        "document_type": { "type": "string", "enum": ["research", "prd", "dr", "spec", "plan"] },
        "executed_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["quality", "feasibility"] }
        },
        "iterations": { "type": "integer", "minimum": 0 },
        "auto_repairs_summary": { "type": "array", "items": { "type": "string" } },
        "remaining_or_confirmation_items": { "type": "array", "items": { "type": "string" } },
        "blocked": { "type": "boolean" },
        "quality_summary": { "type": "string" }
      }
    }
  }
}
